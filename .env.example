# 众包小程序后端 - 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ===== 数据库配置 =====
MYSQL_ROOT_PASSWORD=your-strong-password-here
MYSQL_DATABASE=crowdsource
MYSQL_PORT=3306

# ===== Redis 配置 =====
REDIS_PORT=6379

# ===== 应用配置 =====
APP_PORT=8080

# JWT 配置（必须修改，至少 32 位）
JWT_SECRET=your-production-secret-key-at-least-32-characters-long
JWT_EXPIRATION=604800000

# JVM 配置
JAVA_OPTS=-Xmx512m -Xms256m

# ===== 时区配置 =====
TZ=Asia/Shanghai
