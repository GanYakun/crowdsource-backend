# 众包小程序后端 - 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ===== 数据库配置（使用现有 MySQL 容器）=====
# 注意：MySQL 容器名必须是 mysql，且在同一 Docker 网络中
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=crowdsource_db
MYSQL_USER=cs_user
MYSQL_PASSWORD=Ganyakun0506,

# ===== Redis 配置 =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== 应用配置 =====
APP_PORT=8080

# JWT 配置（必须修改，至少 32 位）
JWT_SECRET=your-production-secret-key-at-least-32-characters-long
JWT_EXPIRATION=604800000

# JVM 配置
JAVA_OPTS=-Xmx512m -Xms256m

# ===== 时区配置 =====
TZ=Asia/Shanghai
